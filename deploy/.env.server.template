# CCC Hub Server — Environment Template
# This file is for the node running the CCC API server (the hub).
# Agent nodes only need deploy/.env.template.
#
#   cp deploy/.env.server.template ~/.ccc/.env && nano ~/.ccc/.env

# ── CCC API Server ────────────────────────────────────────────────────────
CCC_PORT=8789
# Comma-separated list of valid Bearer tokens accepted by this server.
# Generate one per agent with: openssl rand -hex 16
CCC_AUTH_TOKENS=

# Admin token — operator-only. Used for write operations (secret rotation,
# bootstrap token generation, agent registration). NEVER distribute to agents.
# Generate with: openssl rand -hex 32
CCC_ADMIN_TOKEN=

# ── Hub Agent Identity ────────────────────────────────────────────────────
AGENT_NAME=
AGENT_HOST=
CCC_AGENT_TOKEN=  # hub's own bearer token (must be listed in CCC_AUTH_TOKENS)

# ── Object Storage: MinIO ─────────────────────────────────────────────────
# Internal S3-compatible storage for agent state, shared assets, binaries.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=agents
MINIO_ALIAS=ccc-hub

# ── Public Asset Storage: Azure Blob (or compatible) ─────────────────────
AZURE_BLOB_PUBLIC_URL=
AZURE_BLOB_SAS_TOKEN=

# ── Slack ─────────────────────────────────────────────────────────────────
# Slack Bolt (Socket Mode). Both tokens required.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=

# ── Mattermost ────────────────────────────────────────────────────────────
MATTERMOST_TOKEN=
MATTERMOST_URL=

# ── GitHub ────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
WATCH_CHANNEL=

# ── TokenHub ──────────────────────────────────────────────────────────────
TOKENHUB_URL=http://localhost:8090
TOKENHUB_API_KEY=

# ── NVIDIA Inference ──────────────────────────────────────────────────────
NVIDIA_API_BASE=https://inference-api.nvidia.com/v1
NVIDIA_API_KEY=
