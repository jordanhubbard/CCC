<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.acc.accfs-mount</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>mkdir -p /Volumes/accfs &amp;&amp; /sbin/mount_smbfs //AGENT_SMB_USER@AGENT_SMB_HOST/AGENT_SMB_SHARE /Volumes/accfs 2&gt;&gt; AGENT_HOME/.acc/logs/accfs-mount.log &amp;&amp; ln -sfn /Volumes/accfs AGENT_HOME/.acc/shared || true</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <false/>
    <key>StandardOutPath</key>
    <string>AGENT_HOME/.acc/logs/accfs-mount.log</string>
    <key>StandardErrorPath</key>
    <string>AGENT_HOME/.acc/logs/accfs-mount.log</string>
</dict>
</plist>
