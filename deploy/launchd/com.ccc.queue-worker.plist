<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ccc.queue-worker</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>AGENT_HOME/.ccc/workspace/deploy/queue-worker.py</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>AGENT_HOME/.ccc/logs/queue-worker.log</string>
    <key>StandardErrorPath</key>
    <string>AGENT_HOME/.ccc/logs/queue-worker.log</string>
    <key>ThrottleInterval</key>
    <integer>10</integer>
</dict>
</plist>
