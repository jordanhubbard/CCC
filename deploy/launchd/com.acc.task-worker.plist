<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.acc.task-worker</string>
    <key>ProgramArguments</key>
    <array>
        <string>AGENT_HOME/.acc/bin/acc-agent</string>
        <string>tasks</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>AGENT_HOME/.local/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
    <key>KeepAlive</key>
    <true/>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>AGENT_HOME/.acc/logs/task-worker.log</string>
    <key>StandardErrorPath</key>
    <string>AGENT_HOME/.acc/logs/task-worker.log</string>
</dict>
</plist>
