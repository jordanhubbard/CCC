[Unit]
Description=ACC Exec Listener (AgentBus remote exec agent)
Documentation=https://github.com/{OWNER}/CCC
After=network-online.target acc-agent.service
Wants=network-online.target

[Service]
Type=simple
User=AGENT_USER
EnvironmentFile=-AGENT_HOME/.acc/.env
ExecStart=AGENT_HOME/.acc/bin/acc-agent listen
Restart=on-failure
RestartSec=5s

StandardOutput=journal
StandardError=journal
SyslogIdentifier=acc-exec-listen

[Install]
WantedBy=multi-user.target
