# CCC Agent — Environment Template
# Copy to ~/.ccc/.env and fill in your values. NEVER commit .env to git.
#
#   cp deploy/.env.template ~/.ccc/.env && nano ~/.ccc/.env
#
# This file is for agent nodes connecting to an existing CCC hub.
# If you are standing up a new CCC hub, also see deploy/.env.server.template.
#
# ── SECURITY MODEL ─────────────────────────────────────────────────────────
# The only secret you provide at onboarding is CCC_AGENT_TOKEN.
# All other secrets (Slack, NVIDIA, MinIO, etc.) are stored in CCC and synced
# to this file by secrets-sync.sh on each agent-pull run.
# DO NOT manually populate channel or inference secrets below — let
# secrets-sync.sh manage them.

# ── CCC Hub Connection ────────────────────────────────────────────────────
# Provided by your CCC admin at onboarding.
CCC_URL=
CCC_AGENT_TOKEN=

# Optional: Tailscale URL for the hub. If set, ccc-connectivity-check.sh
# will prefer this over the public IP when the current URL is unreachable.
CCC_TAILSCALE_URL=

# Optional: MinIO endpoint on the hub (for agentfs-sync and shared binaries).
CCC_MINIO_URL=

# ── Agent Identity ─────────────────────────────────────────────────────────
AGENT_NAME=
AGENT_HOST=

# ── Agent Capabilities ────────────────────────────────────────────────────
AGENT_CLAUDE_CLI=false
AGENT_CLAUDE_MODEL=claude-sonnet-4-6
AGENT_HAS_GPU=false
AGENT_GPU_MODEL=
AGENT_GPU_COUNT=0
AGENT_GPU_VRAM_GB=0

# ── vLLM (local GPU model serving) ──────────────────────────────────────
# Only relevant on GPU nodes. Auto-detected by bootstrap/setup scripts.
VLLM_ENABLED=false
VLLM_MODEL=google/gemma-4-31B-it
VLLM_SERVED_NAME=gemma
VLLM_PORT=8000
VLLM_MODEL_PATH=
VLLM_EXTRA_ARGS=

# ── TokenHub ──────────────────────────────────────────────────────────────
# Local LLM routing proxy (OpenAI-compatible). Defaults to localhost.
TOKENHUB_URL=http://localhost:8090
TOKENHUB_API_KEY=
TOKENHUB_ADMIN_TOKEN=

# ── NVIDIA Inference ──────────────────────────────────────────────────────
NVIDIA_API_BASE=https://inference-api.nvidia.com/v1
NVIDIA_API_KEY=

# ── ClawBus ───────────────────────────────────────────────────────────────
# Shared secret for HMAC-signed exec payloads.
CLAWBUS_TOKEN=

# ── Qdrant Vector DB ──────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
EMBED_MODEL=azure/openai/text-embedding-3-large
EMBED_DIM=3072

# ── Messaging ─────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=
SLACK_TOKEN=
SLACK_SIGNING_SECRET=

# ── Tailscale ─────────────────────────────────────────────────────────────
# Pre-auth key for unattended node registration (optional).
TS_AUTHKEY=
