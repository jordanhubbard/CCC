# RCC Agent Node — Environment Template
# Copy this to .env and fill in values. NEVER commit .env to git.
#
# Run: cp deploy/.env.template ~/.rcc/.env && nano ~/.rcc/.env

# ── RCC Connection ─────────────────────────────────────────────────────────
# URL of the Rocky Command Center API (the hub — Rocky on do-host1)
# Public: http://YOUR_PUBLIC_IP:8789
# Tailscale: http://YOUR_TAILSCALE_IP:8789
RCC_URL=http://YOUR_PUBLIC_IP:8789
# Bearer token for this agent — use the shared token below, or get one from Rocky
# (issued by RCC admin after registration via deploy/register-agent.sh)
RCC_AGENT_TOKEN=RCC_AUTH_TOKEN_PLACEHOLDER

# ── Agent Identity ─────────────────────────────────────────────────────────
# Short name for this agent (rocky, bullwinkle, natasha, boris, or custom)
AGENT_NAME=
# Human-readable hostname for display in dashboard
AGENT_HOST=

# ── Agent Capabilities (declare what this node can do) ───────────────────
# Does this node have a Claude CLI session running in tmux? (true/false)
AGENT_CLAUDE_CLI=false
# Which Claude model? (e.g. claude-sonnet-4-6)
AGENT_CLAUDE_MODEL=claude-sonnet-4-6
# Does this node have GPU(s)? (true/false)
AGENT_HAS_GPU=false
# GPU model string (e.g. "L40", "H100", "RTX 4090", "Blackwell B200")
AGENT_GPU_MODEL=
# Number of GPUs
AGENT_GPU_COUNT=0
# Total GPU VRAM in GB
AGENT_GPU_VRAM_GB=0

# ── NVIDIA Inference ───────────────────────────────────────────────────────
# NVIDIA inference gateway (standard endpoint)
NVIDIA_API_BASE=https://inference-api.nvidia.com/v1
# API key from NVIDIA portal (rate-limited but real LLM access)
NVIDIA_API_KEY=

# ── Storage: MinIO (internal fast storage) ────────────────────────────────
# Internal S3-compatible endpoint (Tailscale or private network only)
# Rocky hosts MinIO on do-host1. Use Tailscale IP if available, else public.
MINIO_ENDPOINT=http://YOUR_TAILSCALE_IP:9000
MINIO_ACCESS_KEY=MINIO_ACCESS_KEY_PLACEHOLDER
MINIO_SECRET_KEY=MINIO_SECRET_KEY_PLACEHOLDER
# Bucket name (agents is the standard shared bucket)
MINIO_BUCKET=agents
MINIO_ALIAS=do-host1

# ── Storage: Azure Blob (public assets) ───────────────────────────────────
# Public read URL base (no auth needed to read)
AZURE_BLOB_PUBLIC_URL=https://your-storage-account.blob.core.windows.net/assets
# SAS token URL for writes (expires — rotate periodically)
# Full URL pattern: ${AZURE_BLOB_PUBLIC_URL}/<filename>?<sas_token>
AZURE_BLOB_SAS_TOKEN=

# ── Channel Integrations (optional — set what this node uses) ─────────────
# Slack bot token (xoxb-...)
SLACK_TOKEN=
# Mattermost personal access token — get your own from Rocky (DM him your agent name)
MATTERMOST_TOKEN=
MATTERMOST_URL=https://chat.yourmom.photos
# Telegram bot token
TELEGRAM_TOKEN=

# ── RCC API (only needed if THIS node is running the RCC API server) ───────
RCC_PORT=8789
# Comma-separated list of valid auth tokens (for RCC API server)
RCC_AUTH_TOKENS=

# Slack integration for #watch-projects
SLACK_TOKEN=xoxb-...               # your Slack workspace bot token (same as SLACK_TOKEN above, kept for scout compat)
WATCH_CHANNEL=                     # #watch-projects channel ID (get from Slack channel URL)
