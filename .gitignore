# Dependencies
node_modules/
**/node_modules/

# hermes-agent fork (separate repo, not a submodule)
hermes-agent/

# Sensitive / personal
memory/
MEMORY.md
USER.md
BOOTSTRAP.md
*.env
.env.*
.env
!deploy/.env.template

# Per-instance agent files (IPs, hostnames, SSH strings)
# config.md and personality.md are gitignored; SOUL.md CAN be committed
deploy/agents/*/config.md
deploy/agents/*/personality.md
!deploy/agents/TEMPLATE/

# Per-instance onboarding docs (contain live tokens and IPs)
onboarding/ONBOARD_*.md
!onboarding/ONBOARD_*.md.tmpl

# Per-instance operational state
capabilities-manifest.json
data/exec.jsonl
workqueue/heartbeats.jsonl
people/

# Generated configs (rendered from *.tmpl by make init-rcc)
# These contain real hostnames/tokens — never commit them
onboarding/ONBOARD_*.rendered.md

# Runtime data dirs (contain secrets / ephemeral state)
logs/

# Queue state (runtime data, not source)
workqueue/queue.json
workqueue/state-*.json
workqueue/sync-log.jsonl
memory/heartbeat-state.json
memory/channel-state.json

# Logs and temp
*.log
*.bak
workqueue/*.bak*
crash-reports/

# Build artifacts
dist/
.cache/

# Python type-check cache (local experiments / one-off scripts)
.mypy_cache/

