[Unit]
Description=AgentFS Sync — MinIO workspace sync daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=AGENT_USER
EnvironmentFile=-/home/AGENT_USER/.rcc/.env
ExecStart=/usr/local/bin/agentfs-sync
Restart=always
RestartSec=15
StandardOutput=append:/home/AGENT_USER/.rcc/logs/agentfs-sync.log
StandardError=append:/home/AGENT_USER/.rcc/logs/agentfs-sync.log

[Install]
WantedBy=multi-user.target
